{
	"name": "@live-demo/rspress",
	"version": "2.0.6",
	"description": "Rspress plugin for interactive code examples.",
	"bugs": "https://github.com/ViktorZhurbin/live-demo/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ViktorZhurbin/live-demo.git",
		"directory": "packages/rspress"
	},
	"homepage": "https://live-demo.pages.dev",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./web": {
			"types": "./dist/web/index.d.ts",
			"import": "./dist/web/index.mjs",
			"default": "./dist/web/index.mjs"
		},
		"./web/index.css": "./dist/web/index.css"
	},
	"files": [
		"dist",
		"static"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc -p tsconfig.typecheck.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@codemirror/lang-javascript": "^6.2.5",
		"@mantine/hooks": "^8.3.10",
		"@tabler/icons-react": "^3.44.0",
		"@uiw/codemirror-theme-vscode": "^4.25.11",
		"@uiw/react-codemirror": "^4.25.11",
		"clsx": "^2.1.1",
		"oxc-parser": "^0.140.0",
		"react": "^19",
		"react-dom": "^19",
		"react-error-boundary": "^6.1.2",
		"react-resizable-panels": "^3.0.4",
		"rsbuild-plugin-virtual-module": "^0.4.5"
	},
	"devDependencies": {
		"@babel/standalone": "8.0.4",
		"@babel/types": "^7.29.7",
		"@oxc-project/types": "^0.140.0",
		"@rollup/browser": "4.62.2",
		"@rspress/core": "^2.0.18",
		"@tsdown/css": "^0.22.9",
		"@types/babel__core": "^7.20.5",
		"@types/babel__standalone": "^7.1.9",
		"@types/mdast": "^4.0.4",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitest/coverage-v8": "^4.1.10",
		"react": "^19",
		"tsdown": "0.22.9",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"@codemirror/autocomplete": "^6.20.0",
		"@codemirror/language": "^6.11.3",
		"@codemirror/lint": "^6.9.2",
		"@codemirror/search": "^6.5.11",
		"@mdx-js/mdx": ">=2.3.0",
		"@rspress/core": ">=2.0.0",
		"mdast-util-mdx": ">=3.0.0",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0",
		"remark-gfm": ">=3.0.0",
		"unified": ">=11.0.0",
		"unist-util-visit": ">=4.0.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"keywords": [
		"rspress",
		"@rspress/core",
		"plugin",
		"live-demo",
		"playground",
		"live-code",
		"code-editor"
	]
}
