{
	// Type-checking only (`tsc --noEmit`). The base tsconfig deliberately omits
	// module resolution because tsdown injects it at build time; this file adds
	// bundler-style resolution so `tsc` can resolve imports on its own.
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"noEmit": true,
		// static/ imports the package's own public API by its published name, as
		// a consumer would. Point that at src instead of dist so typecheck (which
		// CI runs before build) doesn't depend on dist already being built.
		"paths": {
			"node/*": ["./src/node/*"],
			"shared/*": ["./src/shared/*"],
			"web/*": ["./src/web/*"],
			"@live-demo/rspress/web": ["./src/web/index.ts"]
		}
	}
}
