{
	"name": "live-demo-monorepo",
	"private": true,
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build:lib": "pnpm --filter '@live-demo/rspress' build",
		"build:web": "pnpm build:lib && pnpm --filter 'website' build",
		"release": "pnpm build:lib && pnpm --filter '@live-demo/rspress' publish",
		"typecheck": "pnpm --recursive run typecheck",
		"test": "pnpm --recursive run test",
		"knip": "pnpm --recursive --if-present run knip",
		"verify": "pnpm build:web && pnpm typecheck && pnpm test && pnpm knip",
		"format": "oxfmt",
		"lint": "oxlint --fix --format=agent",
		"check": "pnpm run format && pnpm run lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.13.1"
}
