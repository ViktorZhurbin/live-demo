{
	"name": "live-demo-monorepo",
	"private": true,
	"scripts": {
		"prepublish": "pnpm build:lib",
		"publish": "pnpm --filter '@live-demo/rspress' publish",
		"build:web": "pnpm build:lib && pnpm --filter website build",
		"build:lib": "pnpm --filter '@live-demo/rspress' build",
		"format": "biome check --write",
		"prepare": "husky",
		"test": "pnpm -r run test",
		"test:ui": "pnpm -r run test:ui",
		"test:coverage": "pnpm -r run test:coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.9",
		"husky": "^9.1.7"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.13.1",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
