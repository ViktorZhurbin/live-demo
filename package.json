{
	"name": "live-demo-monorepo",
	"private": true,
	"scripts": {
		"build:lib": "pnpm --filter '@live-demo/rspress' build",
		"build:web": "pnpm build:lib && pnpm --filter 'website' build",
		"release": "pnpm build:lib && pnpm --filter '@live-demo/rspress' publish",
		"typecheck": "pnpm --recursive run typecheck",
		"test": "pnpm --recursive run test",
		"format": "biome check --write",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"husky": "^9.1.7",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.13.1",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
