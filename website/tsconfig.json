{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["DOM", "ES2020"],
		"jsx": "react-jsx",
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"useDefineForClassFields": true,
		"allowImportingTsExtensions": true,

		"paths": {
			"components/*": ["./src/components/*"]
		}
	},
	"include": ["docs", "src", "rspress.config.ts"],
	"mdx": {
		"checkMdx": true
	}
}
